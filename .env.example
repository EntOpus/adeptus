# Database
DATABASE_URL=postgresql://adeptus:password@localhost:5432/adeptus
ADEPTUS__DATABASE__URL=postgresql://adeptus:password@localhost:5432/adeptus
ADEPTUS__DATABASE__MAX_CONNECTIONS=20
ADEPTUS__DATABASE__MIN_CONNECTIONS=5
ADEPTUS__DATABASE__RUN_MIGRATIONS=true

# Server
ADEPTUS__SERVER__HOST=0.0.0.0
ADEPTUS__SERVER__PORT=3000
ADEPTUS__SERVER__TIMEOUT_SECONDS=30

# NATS (optional)
# ADEPTUS__NATS__URL=nats://localhost:4222
ADEPTUS__NATS__STREAM_NAME=ADEPTUS_EVENTS
ADEPTUS__NATS__MAX_AGE_DAYS=30

# Keto (optional)
# ADEPTUS__KETO__READ_URL=http://keto:4466

# Pactum (optional)
# ADEPTUS__PACTUM__GRAPHQL_URL=http://pactum:3004/graphql

# Rate Limiting
ADEPTUS__RATE_LIMITING__ENABLED=true
ADEPTUS__RATE_LIMITING__GLOBAL_LIMIT=10000
ADEPTUS__RATE_LIMITING__PER_USER_LIMIT=1000
ADEPTUS__RATE_LIMITING__PER_IP_LIMIT=100
ADEPTUS__RATE_LIMITING__BURST_SIZE=10

# Observability
ADEPTUS__OBSERVABILITY__LOGGING__LEVEL=info
ADEPTUS__OBSERVABILITY__LOGGING__FORMAT=pretty
ADEPTUS__OBSERVABILITY__TRACING__ENABLED=false
# ADEPTUS__OBSERVABILITY__TRACING__OTLP_ENDPOINT=http://localhost:4317
ADEPTUS__OBSERVABILITY__METRICS__ENABLED=true

# PDF Generation
ADEPTUS__PDF__WKHTMLTOPDF_PATH=wkhtmltopdf
ADEPTUS__PDF__TEMP_DIR=/tmp/adeptus-pdf
ADEPTUS__PDF__GENERATION_TIMEOUT_SECONDS=30

# CDN (optional)
ADEPTUS__CDN__ENABLED=false
# ADEPTUS__CDN__BASE_URL=https://cdn.example.com
# ADEPTUS__CDN__API_KEY=your-api-key
# ADEPTUS__CDN__BUCKET_NAME=adeptus-files
# ADEPTUS__CDN__UPLOAD_TIMEOUT_SECONDS=30

# File Storage
ADEPTUS__FILE_STORAGE__UPLOAD_DIR=./uploads
ADEPTUS__FILE_STORAGE__MAX_FILE_SIZE=104857600
